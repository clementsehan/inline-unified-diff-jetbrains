<!--
    Loaded only when the Kotlin plugin (org.jetbrains.kotlin) is present.

    Declares K2 mode compatibility. Our PSI usage (KtNamedFunction,
    KtNameReferenceExpression) is structural traversal only — no K1-specific
    analysis APIs — so this opt-in is accurate.
-->
<idea-plugin>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>
